# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
*.git
*.gitignore
*.gitmodules
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
README.md.gotmpl
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# GitLab CI
*.gitlab-ci.yml
# Builded chart
*.tgz
.releaserc.yml